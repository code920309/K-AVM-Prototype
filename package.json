{
  "name": "k-avm-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "front",
    "server",
    "db"
  ],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"Server,Front\" -c \"yellow,blue\" \"npm run dev:server\" \"npm run dev:front\"",
    "dev:front": "npm run dev --workspace=front",
    "dev:server": "npm run start --workspace=server",
    "build:front": "npm run build --workspace=front",
    "db:seed": "server\\venv\\Scripts\\python db\\seed.py"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
